# ─────────────────────────────────────────────
#  Mochi Bot — Environment Variables
# ─────────────────────────────────────────────

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_token_bot

# Application (client) ID of your bot
CLIENT_ID=your_client_id_bot

# Discord user ID of the bot owner (used for /eval and owner-only guards)
OWNER_ID=your_user_id_here

